# ── Database ──────────────────────────────────────────────────────────────────
# Prisma / PostgreSQL connection string (from Supabase → Project Settings → Database)
DATABASE_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and anon key (from Supabase → Project Settings → API)
# These are intentionally public — security is enforced by RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── ExerciseDB (RapidAPI) ─────────────────────────────────────────────────────
# Server-only key — never expose to the browser or commit this value.
# Get yours at https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
EXERCISES_API_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
# Full origin of your deployment, used for password-reset redirect links.
# Local dev default (http://localhost:3000) is used when this is not set.
# Production example: https://fitlog.vercel.app
NEXT_PUBLIC_SITE_URL=
